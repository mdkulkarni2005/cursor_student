    {
      "name": "admin",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "admin", "dev"],
      "port": 3100
    },
    {
      "name": "recruiter",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "recruiter", "dev"],
      "port": 3200
    }
  ]
