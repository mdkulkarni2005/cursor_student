{
  "name": "studentos",
  "version": "0.1.0",
  "private": true,
  "description": "StudentOS — the AI academic operating system (Cursor for Students).",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:app": "turbo dev",
    "dev:services": "docker compose up -d",
    "dev:down": "docker compose down",
    "build": "turbo build",
    "lint": "turbo lint",
    "check-types": "turbo check-types",
    "gotenberg": "docker run --rm -p 9000:3000 gotenberg/gotenberg:8",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "dsa:verify": "tsx scripts/dsa-verify/verify.ts"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
