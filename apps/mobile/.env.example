# Same Clerk instance as apps/web — copy the value from apps/web/.env.local
# (NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY). Same account, same session provider.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# apps/web's URL. It must actually be running (`pnpm run dev` from the repo root, in a
# separate terminal from `expo start`) — this app has no `dev` script of its own and won't
# start apps/web for you. In dev, point this at your machine's LAN IP (not localhost — a
# physical device/simulator can't reach your laptop's localhost), e.g. http://192.168.1.23:3000
# — `next dev` runs on port 3000 by default. In prod, the same single-VM URL apps/web runs on.
EXPO_PUBLIC_API_URL=http://localhost:3000
