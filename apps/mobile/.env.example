# Same Clerk instance as apps/web — copy the value from apps/web/.env.local
# (NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY). Same account, same session provider.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# apps/web's URL. In dev, point this at your machine's LAN IP (not localhost —
# a physical device/simulator can't reach your laptop's localhost), e.g.
# http://192.168.1.23:4173. In prod, the same single-VM URL apps/web already runs on.
EXPO_PUBLIC_API_URL=http://localhost:4173
