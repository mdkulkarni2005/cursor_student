// StudentOS data model — Neon Postgres via Prisma.
// Mirrors docs/PLAN.md §6. Every artifact a student makes is a `Document` in a
// `Workspace`; the Academic Vault is just a searchable view over Documents.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Neon: pooled connection for the app...
  url       = env("DATABASE_URL")
  // ...and a direct (unpooled) connection for migrations.
  directUrl = env("DIRECT_URL")
}

// ----------------------------- Enums --------------------------------------

enum Plan {
  FREE
  PRO
  PREMIUM
}

// STUDENT gets the full academic toolkit; PROFESSIONAL is restricted to DSA + mock interview
// (plus the recruiter-driven surfaces: messages, real interview) — see apps/web/lib/nav.ts and
// requireStudentRoute() in apps/web/lib/user.ts for where this is enforced.
enum UserType {
  STUDENT
  PROFESSIONAL
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum DocumentType {
  ASSIGNMENT
  REPORT
  PPT
  PROJECT
  VIVA
  RESUME
  INTERVIEW
  LAB_REPORT
  BRANCH_SOLVER
  DRAWING_VIVA
}

enum DocumentStatus {
  DRAFT
  QUEUED
  GENERATING
  NEEDS_INPUT
  READY
  FAILED
}

enum TemplateType {
  REPORT
  PPT
  RESUME
}

enum ExportFormat {
  DOCX
  PPTX
  PDF
}

enum JobStatus {
  QUEUED
  RUNNING
  NEEDS_INPUT
  SUCCEEDED
  FAILED
}

enum UploadKind {
  PHOTO
  PDF
  IMAGE
  OTHER
}

// quota dimensions enforced by plan-gating (PLAN.md §8)
enum UsageKind {
  ASSIGNMENT
  REPORT
  PPT
  LAB_REPORT
  // Shared quota bucket for every branch-specific tool (numerical solvers + drawing viva prep) —
  // deliberately one bucket, not one per feature, since each is a small niche tool.
  BRANCH_SOLVER
}

// Recruiter onboarding lifecycle. DRAFT = still filling the multi-step form (resumable on
// reconnect); PENDING = submitted, awaiting apps/admin review; APPROVED/REJECTED = decided.
enum RecruiterStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

// Lifecycle of a recruiter-proposed REAL interview slot (distinct from the student's self-serve
// mock interview / Document(type=INTERVIEW)). PROPOSED = awaiting student response; RESCHEDULE_
// REQUESTED = student countered with a different time (recruiter decides next); COMPLETED = the
// time has passed and the recruiter logged an outcome.
enum InterviewScheduleStatus {
  PROPOSED
  ACCEPTED
  DECLINED
  RESCHEDULE_REQUESTED
  CANCELED
  COMPLETED
  RESCHEDULE_DECLINED
}

enum InterviewOutcome {
  SELECTED
  REJECTED
  ON_HOLD
}

// ----------------------------- Core ---------------------------------------

model User {
  id           String    @id @default(cuid())
  clerkId      String    @unique
  email        String    @unique
  name         String?
  // Academic context — powers department/semester-aware generation.
  department   String?
  semester     String?
  // GPA/CGPA out of 10, self-reported at onboarding — optional, shown publicly on /u/[handle]
  // when present (no visibility toggle, unlike visibleToRecruiters below).
  gpa          Float?
  // Career intent captured at onboarding (e.g. "Software Engineer") — powers career-goal mapping.
  careerGoal   String?
  // Public shareable profile handle (e.g. "arjun-mehta-4f2a"). Null = the student hasn't shared
  // their profile yet; set on first "Share Profile". Resolves /u/[handle].
  publicHandle String?   @unique
  onboardedAt  DateTime?
  plan         Plan      @default(FREE)
  userType     UserType  @default(STUDENT)

  // Required contact/identity links — collected at onboarding for both STUDENT and PROFESSIONAL
  // users. Gate the "Share Profile" action (see apps/web/lib/actions/profile.ts): a student can't
  // generate a /u/[handle] link until both are set. Nullable here only because existing users
  // predate this requirement and must be prompted to fill them in after the fact.
  githubUrl String?
  linkedin  String?

  // Working-professional onboarding context (null for STUDENT) — surfaced to recruiters so they
  // can reach out directly instead of guessing from a resume.
  companyName       String?
  jobTitle          String?
  yearsOfExperience Int?

  // Branch-aware capability: coding track (DSA + coding interview round). Department seeds the
  // default at onboarding, but the student can opt in/out. Default true = fail-open (show everything).
  codingEnabled   Boolean   @default(true)
  // Legal acceptance — captured as the last step of onboarding.
  acceptedLegalAt DateTime?
  // Lightweight activity metrics for the admin panel (no per-token accounting).
  lastSeenAt      DateTime?
  appOpens        Int       @default(0)
  // Throttle for the concurrent-session enforcement check (see apps/web/lib/sessions.ts) — separate
  // from lastSeenAt's 30-min window because the anti-account-sharing check needs to run more often.
  sessionCheckedAt DateTime?

  // Admin-controlled account hold. Enforced in apps/web's requireOnboardedUser — a suspended
  // user is bounced to /suspended instead of the app. Set/cleared only from apps/admin.
  suspended   Boolean   @default(false)
  suspendedAt DateTime?

  // Auto-generated project ideas cached for the Projects landing page (department/career-goal
  // aware), so a student sees suggestions immediately instead of asking first. Generated lazily
  // on first visit; refreshed on demand, not automatically re-run on every profile edit.
  pregeneratedIdeas   Json?
  pregeneratedIdeasAt DateTime?

  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id])

  // College ID card photo, required at onboarding for STUDENT — proof gating student-only
  // features from non-students. R2 object key (see @studentos/storage keys.idCard). Null for
  // PROFESSIONAL users, and for STUDENT accounts that predate this requirement.
  idCardKey String?

  // Unique contact number — cross-checked against Recruiter.phone too (see
  // packages/db/src/phone.ts) so the same person can't register twice across student/recruiter.
  // Not used for SMS/notifications yet, only identity de-duplication at onboarding.
  phone String? @unique

  // Recruiter-side discovery — on by default; a student can explicitly opt out from their
  // profile. Gates visibility in apps/recruiter's student search only; does not affect the
  // existing /u/[handle] public profile.
  visibleToRecruiters   Boolean   @default(true)
  visibleToRecruitersAt DateTime?

  workspaces         Workspace[]
  documents          Document[]
  uploads            Upload[]
  subscription       Subscription?
  payments           Payment[]
  usageEvents        UsageEvent[]
  dsaAttempts        DsaAttempt[]
  assistantThread    AssistantThread?
  deadlines          Deadline[]
  studyPlans         StudyPlan[]
  recruiterMessages  RecruiterMessage[]
  interviewSchedules InterviewSchedule[]
  supportTickets     SupportTicket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([institutionId])
  @@index([visibleToRecruiters])
}

model Institution {
  id         String     @id @default(cuid())
  name       String // college name
  university String?
  users      User[]
  templates  Template[]
  createdAt  DateTime   @default(now())

  @@unique([name, university])
}

// A locked institutional template. The AI never emits layout — it fills these slots.
model Template {
  id            String       @id @default(cuid())
  type          TemplateType
  name          String
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id])
  // R2 object key of the .docx/.pptx template asset.
  storageKey    String
  schemaVersion Int          @default(1)
  // Declared placeholder slots, for validation against generated content.
  placeholders  Json?
  isDefault     Boolean      @default(false)

  documents Document[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([type, institutionId])
}

// ----------------------------- Workspace ----------------------------------

model Workspace {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  semester  String?
  subjects  Subject[]
  documents Document[]
  createdAt DateTime   @default(now())

  @@index([userId])
}

model Subject {
  id          String     @id @default(cuid())
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  code        String?
  documents   Document[]
  deadlines   Deadline[]

  @@index([workspaceId])
}

// ----------------------------- Documents ----------------------------------

model Document {
  id      String         @id @default(cuid())
  ownerId String
  owner   User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  type    DocumentType
  title   String
  status  DocumentStatus @default(DRAFT)
  /** Branch-solver feature slug (e.g. "mech-solver", "structural-checker") — see lib/capabilities.ts. */
  feature String?

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  subjectId   String?
  subject     Subject?   @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  templateId  String?
  template    Template?  @relation(fields: [templateId], references: [id])

  // Latest plagiarism / AI-detection metrics: { aiScore, plagiarismScore, humanized }
  quality Json?

  content DocumentContent?
  exports DocumentExport[]
  job     GenerationJob?
  viva    VivaSet?
  uploads Upload[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, type])
  @@index([ownerId, status])
}

// The structured, schema-validated content the model produced (the renderer's input).
model DocumentContent {
  id            String   @id @default(cuid())
  documentId    String   @unique
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  schemaVersion Int      @default(1)
  data          Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// A rendered file (DOCX/PPTX/PDF) stored in R2.
model DocumentExport {
  id         String       @id @default(cuid())
  documentId String
  document   Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  format     ExportFormat
  storageKey String
  sizeBytes  Int?
  createdAt  DateTime     @default(now())

  @@index([documentId])
}

// Async generation tracking — heavy work runs off-request so mobile users never lose progress.
model GenerationJob {
  id         String    @id @default(cuid())
  documentId String    @unique
  document   Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  status     JobStatus @default(QUEUED)
  model      String?
  inputRefs  Json?
  // When paused at NEEDS_INPUT: { questions, title, reportType, guidelines, templateKey }
  pending    Json?
  error      String?
  costCents  Int       @default(0)
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
}

model Upload {
  id         String     @id @default(cuid())
  ownerId    String
  owner      User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  documentId String?
  document   Document?  @relation(fields: [documentId], references: [id], onDelete: SetNull)
  storageKey String
  mime       String
  sizeBytes  Int
  kind       UploadKind @default(OTHER)
  createdAt  DateTime   @default(now())

  @@index([ownerId])
}

model VivaSet {
  id         String   @id @default(cuid())
  documentId String   @unique
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  // [{ question, answer, difficulty }]
  questions  Json
  createdAt  DateTime @default(now())
}

// ----------------------------- Billing ------------------------------------

model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan               Plan               @default(FREE)
  status             SubscriptionStatus @default(ACTIVE)
  razorpaySubId      String?            @unique
  razorpayCustomerId String?
  currentPeriodEnd   DateTime?
  // Recurring mandate is live at Razorpay (razorpaySubId set) unless the student has requested
  // cancellation, in which case it still runs until currentPeriodEnd but won't renew. "Autopay" in
  // the admin UI = razorpaySubId != null && !cancelAtPeriodEnd.
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

enum PaymentStatus {
  CAPTURED
  FAILED
  REFUNDED
}

// One row per Razorpay payment event (captured/failed/refunded) — the payment history + receipt
// trail. Populated by the Razorpay webhook (apps/web/app/api/webhooks/razorpay), not written
// directly from the app, so this only reflects what Razorpay actually processed.
model Payment {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  razorpayPaymentId String        @unique
  razorpayOrderId   String?
  amountCents       Int
  currency          String        @default("INR")
  status            PaymentStatus
  method            String?
  // Razorpay-hosted receipt/invoice URL when the webhook payload includes one.
  receiptUrl        String?
  createdAt         DateTime      @default(now())

  @@index([userId, createdAt])
}

// One row per quota-consuming generation; counted per billing period for plan-gating.
model UsageEvent {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind       UsageKind
  documentId String?
  createdAt  DateTime  @default(now())

  @@index([userId, kind, createdAt])
}

// Persisted always-on assistant chat — one rolling thread per user (messages = [{role,content}]).
model AssistantThread {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Json     @default("[]")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// DSA practice attempts (append-only). Problems live in code (static catalog), referenced by slug.
// Streaks are DERIVED from these timestamps (IST), never a stored counter. `solved` is self-marked.
model DsaAttempt {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemSlug String
  language    String?
  code        String
  solved      Boolean  @default(false)
  review      Json? // AI review: { timeComplexity, spaceComplexity, feedback, suggestions[] }
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, problemSlug])
}

// ----------------------------- Semester planning --------------------------

// A dated obligation (exam, quiz, lab, paper) — powers Semester Hub "Critical Deadlines"
// and Subject Detail "Upcoming". Optionally tied to a subject.
model Deadline {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  title     String
  // exam | quiz | lab | paper | assignment | other
  kind      String   @default("other")
  dueAt     DateTime
  done      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, dueAt])
}

// An AI-generated exam-prep plan — powers the Exam Planner. `roadmap` holds the day-by-day
// plan JSON; `readiness` is a 0–100 estimate.
model StudyPlan {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetExam String
  examDate   DateTime?
  readiness  Int       @default(0)
  // [{ day, label, items: [{ text, kind }] }]
  roadmap    Json      @default("[]")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId, createdAt])
}

// ----------------------------- Admin ---------------------------------------

// Append-only record of every mutating action taken from apps/admin. Never updated or deleted —
// this is the accountability trail for plan overrides, suspensions, deletes, and template edits.
model AdminAuditLog {
  id         String   @id @default(cuid())
  // The admin's Clerk email (not a User relation — admins may not have a student User row).
  actorEmail String
  // e.g. "user.plan.set", "user.suspend", "user.reactivate", "user.data.delete", "job.retry"
  action     String
  targetType String
  targetId   String
  // Free-form before/after snapshot for diffing what changed.
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([createdAt])
}

// Small admin-editable key/value store for platform-wide config — currently just the concurrent
// session cap (key "MAX_CONCURRENT_SESSIONS"), read by apps/web's session-enforcement check.
model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ----------------------------- Recruiter -----------------------------------

// A recruiter account (apps/recruiter). Distinct from `User` (students) — recruiters never get a
// student row. Clerk `publicMetadata.role: "recruiter"` is only granted once `status` flips to
// APPROVED (set from apps/admin's verification queue), so it can't be self-assigned.
model Recruiter {
  id              String          @id @default(cuid())
  clerkId         String          @unique
  email           String          @unique
  name            String?
  // Cross-checked against User.phone (packages/db/src/phone.ts) — one person, one identity,
  // whether they sign up as a student or a recruiter.
  phone           String?         @unique
  companyName     String?
  companyEmail    String?
  // Free-text industry/domain the recruiter hires for — matched against student `careerGoal`
  // (packages/db/src/recruiter-matching.ts). "" / null = sees all industries.
  industry        String?
  designation     String?
  linkedinUrl     String?
  status          RecruiterStatus @default(DRAFT)
  rejectionNote   String?
  // The reviewing admin's Clerk email (mirrors AdminAuditLog.actorEmail — no admin User relation).
  approvedByEmail String?
  approvedAt      DateTime?

  messages       RecruiterMessage[]
  schedules      InterviewSchedule[]
  supportTickets SupportTicket[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status])
  @@index([industry])
}

// A recruiter → student direct message. One-directional by design (v1): students read and reply
// via a normal reply, but recruiters cannot be messaged back through a separate student->recruiter
// row here — see apps/web's inbox, which only reads, never writes, this table.
model RecruiterMessage {
  id          String           @id @default(cuid())
  recruiterId String
  recruiter   Recruiter        @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  studentId   String
  student     User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  body        String
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  direction   MessageDirection @default(RECRUITER_TO_STUDENT)

  @@index([studentId, createdAt])
  @@index([recruiterId, createdAt])
}

enum MessageDirection {
  RECRUITER_TO_STUDENT
  STUDENT_TO_RECRUITER
}

// A help-desk ticket raised by a student or recruiter, reviewed by apps/admin. Exactly one of
// studentId/recruiterId is set depending on who raised it. Deliberately flat (no threaded replies)
// — the admin's "corrective action" is usually a separate existing admin tool (suspend, reset
// quota, approve/reject) on that user/recruiter's own page; adminNote just records what was done.
model SupportTicket {
  id            String             @id @default(cuid())
  requesterType SupportRequesterType
  studentId     String?
  student       User?              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  recruiterId   String?
  recruiter     Recruiter?         @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  subject       String
  message       String
  status        SupportTicketStatus @default(OPEN)
  adminNote     String?
  resolvedAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([status, createdAt])
  @@index([studentId])
  @@index([recruiterId])
}

enum SupportRequesterType {
  STUDENT
  RECRUITER
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// A recruiter-proposed REAL interview slot with a student — separate from the student's own
// self-serve mock interview (Document(type=INTERVIEW)). v1 is deliberately flat: one recruiter
// proposes one time to one student (no multi-slot/multi-round abstraction yet). Video transport
// is external in v1 — `meetingLink` is whatever Zoom/Meet/Teams link the recruiter already uses;
// see docs/DEFERRED.md "Recruiter real interviews" for the Meet-API / in-house-video upgrade path.
model InterviewSchedule {
  id          String                  @id @default(cuid())
  recruiterId String
  recruiter   Recruiter               @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  studentId   String
  student     User                    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status      InterviewScheduleStatus @default(PROPOSED)
  proposedAt  DateTime
  meetingLink String?
  note        String?
  studentNote String?
  outcome     InterviewOutcome?
  outcomeNote String?
  // Optional link to the JobPosting this interview was scheduled for (via "Select for interview"
  // on a posting's matched-candidates list). Null for ad-hoc interviews scheduled without a
  // posting, same manual-join convention as InterviewRoom/InterviewJudgment below.
  jobPostingId String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([studentId, proposedAt])
  @@index([recruiterId, proposedAt])
  @@index([jobPostingId])
}

enum InterviewRoomStatus {
  PENDING
  ACTIVE
  ENDED
  UNAVAILABLE
}

// LiveKit room/token state for ONE InterviewSchedule (the recruiter-led real interview build,
// docs/BUILD_ORDER.md Phase E). Deliberately NOT a Prisma relation to InterviewSchedule — a
// relation would force a back-relation field onto that model. Joined manually by scheduleId,
// same pattern as ownedSchedule() in apps/web/lib/actions/interview-schedule.ts. Kept isolated so
// this table (and the feature it belongs to) can be dropped cleanly without touching the model
// above.
model InterviewRoom {
  id          String              @id @default(cuid())
  scheduleId  String              @unique
  livekitRoom String
  status      InterviewRoomStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  endedAt     DateTime?
  // Last snapshot of the shared code editor at end-of-call, fed into InterviewJudgment alongside
  // the transcript. Not live-synced here — written once, when the interview is finalized.
  finalCode   String?
  // Pre-join proctoring gate (Phase E6): candidateReadyAt is set once the candidate finishes local
  // checks and enters the LiveKit lobby (no tracks published yet); admittedAt is set once the
  // recruiter lets them in. Durable so state survives page reloads on either side — the live push
  // between candidate and recruiter is a LiveKit data message on top of these.
  candidateReadyAt DateTime?
  admittedAt       DateTime?
  // Best-effort readiness summary (fullscreen/monitor count) captured alongside candidateReadyAt —
  // persisted so a recruiter who connects/reloads AFTER the candidate's one-time LiveKit data
  // message still sees it, not just "checking…" forever.
  candidateChecks  Json?

  @@index([scheduleId])
}

enum InterviewFlagKind {
  FULLSCREEN_EXIT
  TAB_HIDDEN
  CAMERA_OFF
  MIC_OFF
  MULTI_MONITOR
  COPY_PASTE_ATTEMPT
}

// Proctoring signal log for ONE InterviewSchedule (Phase E3). Same isolation pattern as
// InterviewRoom above — no relation, joined manually by scheduleId. MULTI_MONITOR is written at
// most once per session by client-side throttling (see use-proctoring-signals.ts) — nothing here
// enforces that; it's a client-side guarantee only.
model InterviewFlag {
  id         String            @id @default(cuid())
  scheduleId String
  kind       InterviewFlagKind
  detail     String?
  occurredAt DateTime          @default(now())

  @@index([scheduleId, occurredAt])
}

// Text-only transcript line (Phase E4) — captured client-side via the Web Speech API on each
// participant's OWN mic, never audio/video. Same isolation pattern — no relation, manual join.
model InterviewTranscriptLine {
  id         String   @id @default(cuid())
  scheduleId String
  speaker    String // "candidate" | "recruiter"
  text       String
  occurredAt DateTime @default(now())

  @@index([scheduleId, occurredAt])
}

// AI-assisted, recruiter-facing judgment generated once the call ends (Phase E5) — NOT the
// decision-maker, the recruiter is. Same isolation pattern — no relation, manual join by scheduleId.
model InterviewJudgment {
  id             String   @id @default(cuid())
  scheduleId     String   @unique
  fitVerdict     String
  summary        String
  strengths      Json
  concerns       Json
  recommendation String
  // 0-10, additive on top of fitVerdict — nullable since judgments generated before this field
  // existed have no score. Not the decision-maker, same disclaimer as the rest of this model.
  score          Int?
  model          String
  createdAt      DateTime @default(now())
}

enum JobPostingStatus {
  OPEN
  CLOSED
}

enum JobMatchRunStatus {
  IDLE
  RUNNING
  SUCCEEDED
  FAILED
}

// A recruiter-created job posting with a JD, used as the basis for AI candidate matching
// (JobMatch below) and as optional role context for InterviewSchedule/InterviewJudgment. Same
// isolation pattern as the interview-cluster models — no relation to Recruiter, joined manually
// by recruiterId, so this feature stays droppable without touching Recruiter.
model JobPosting {
  id          String           @id @default(cuid())
  recruiterId String
  title       String
  description String
  department  String?
  status      JobPostingStatus @default(OPEN)
  // Mirrors GenerationJob's QUEUED/RUNNING/SUCCEEDED/FAILED shape (packages/db schema, Document
  // generation) but kept as plain fields here rather than a shared model, since JobPosting isn't a
  // Document. Scoring runs via Next's after() outside the request lifecycle (see
  // apps/recruiter/app/jobs/actions.ts) so "Find candidates" can't hit a serverless timeout even
  // once the visible-student pool is large — the client polls these fields instead of awaiting.
  matchStatus      JobMatchRunStatus @default(IDLE)
  matchError       String?
  matchStartedAt   DateTime?
  matchFinishedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([recruiterId, createdAt])
}

// AI-computed match score of one student against one JobPosting (Phase: job matching). Recomputed
// on-demand (recruiter clicks "Find candidates"), never shown to the student — recruiter-only.
// Manual join by jobPostingId/studentId, same isolation pattern as everything above.
model JobMatch {
  id           String   @id @default(cuid())
  jobPostingId String
  studentId    String
  matchPercent Int
  rationale    String
  model        String
  computedAt   DateTime @default(now())

  @@unique([jobPostingId, studentId])
  @@index([jobPostingId, matchPercent])
}

enum SandboxStatus {
  PENDING
  RUNNING
  STOPPED
  UNAVAILABLE
}

// Recruiter-launched full-project code sandbox (Vercel Sandbox) for the coding round — richer than
// the stateless Piston runner (persistent filesystem, package installs, any language/framework).
// Same isolation pattern as InterviewRoom above — no relation, joined manually by scheduleId.
model InterviewSandbox {
  id         String        @id @default(cuid())
  scheduleId String        @unique
  sandboxId  String
  status     SandboxStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  endedAt    DateTime?

  @@index([scheduleId])
}
