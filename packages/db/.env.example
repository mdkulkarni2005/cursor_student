# Neon Postgres — copy to `.env` in this package (and to apps/web/.env.local for the app).
# From the Neon dashboard → Connection Details:
#   DATABASE_URL = the POOLED connection string (host has "-pooler"), used by the app at runtime.
#   DIRECT_URL   = the DIRECT/unpooled connection string, used by Prisma migrations.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"
